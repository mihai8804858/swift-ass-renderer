:null,"caption":[],"code":"customdrawing-3.swift"},{"media":null,"content":[{"inlineContent":[{"type":"text","text":"We need a method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" that will load the subtitle contents and provide it to renderer."}],"type":"paragraph"}],"caption":[],"code":"customdrawing-4.swift","type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Next, let’s load the subtitles contents, either from local disk for web."}],"type":"paragraph"}],"caption":[],"media":null,"type":"step","code":"customdrawing-5.swift","runtimePreview":null},{"caption":[],"media":null,"code":"customdrawing-6.swift","content":[{"inlineContent":[{"type":"text","text":"After contents have been loaded, we need to provide the contents for the renderer by calling "},{"type":"codeVoice","code":"loadTrack(contents:)"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"media":null,"type":"step","code":"customdrawing-7.swift","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We need another method called from "},{"type":"codeVoice","code":"viewDidLoad()"},{"type":"text","text":" that will create a "},{"type":"codeVoice","code":"Timer"},{"type":"text","text":" to periodically update the subtitles time offset."}]}]},{"content":[{"inlineContent":[{"text":"Let’s setup the timer to fire each 0.1 seconds on ","type":"text"},{"type":"codeVoice","code":".main"},{"type":"text","text":" queue."}],"type":"paragraph"}],"code":"customdrawing-8.swift","runtimePreview":null,"type":"step","caption":[],"media":null},{"caption":[],"media":null,"code":"customdrawing-9.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the timer output closure, we need to update the renderer with the time offset since the start date."}]}],"type":"step","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We need another method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" that will subscribe to view’s frame changes and update the renderer’s canvas size and scale."}]}],"runtimePreview":null,"type":"step","code":"customdrawing-10.swift","media":null},{"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"We can use "},{"type":"codeVoice","code":"Combine"},{"type":"text","text":"’s KVO publisher to subscribe to "},{"type":"codeVoice","code":"frame"},{"text":" changes and execute a closure.","type":"text"}],"type":"paragraph"}],"media":null,"code":"customdrawing-11.swift","runtimePreview":null},{"caption":[],"content":[{"inlineContent":[{"text":"When ","type":"text"},{"code":"frame","type":"codeVoice"},{"text":" changed, we need to update the canvas size by calling ","type":"text"},{"type":"codeVoice","code":"setCanvasSize(_:scale:)"},{"type":"text","text":" on renderer,"},{"text":" ","type":"text"},{"type":"text","text":"we can use the display scale as the scale at which the images will be created."}],"type":"paragraph"}],"type":"step","media":null,"code":"customdrawing-12.swift","runtimePreview":null},{"media":null,"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"We need another method called from ","type":"text"},{"type":"codeVoice","code":"viewDidLoad()"},{"type":"text","text":" that will subscribe to renderer’s frame changes and update the drawn image."}],"type":"paragraph"}],"code":"customdrawing-13.swift","caption":[]},{"code":"customdrawing-14.swift","caption":[],"content":[{"inlineContent":[{"type":"codeVoice","code":"AssSubtitlesRenderer"},{"type":"text","text":" privides a publisher where the image changes are being published so they can be drawn on the screen."}],"type":"paragraph"}],"runtimePreview":null,"type":"step","media":null},{"caption":[],"type":"step","code":"customdrawing-15.swift","runtimePreview":null,"content":[{"type":"paragra