.frame = image.imageRect","            imageView.isHidden = false","        } else {","            imageView.image = nil","            imageView.isHidden = true","        }","    }","}"],"identifier":"customdrawing-17.swift","fileName":"SubtitlesViewController.swift"},"doc://swift-ass-renderer.SwiftAssRenderer/tutorials/SwiftAssRenderer/CustomImageDrawing#Custom-Drawing":{"url":"\/tutorials\/swiftassrenderer\/customimagedrawing#Custom-Drawing","abstract":[{"text":"Learn how to manually integrate ","type":"text"},{"type":"codeVoice","code":"AssSubtitlesRenderer"},{"type":"text","text":" with your view."}],"role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/swift-ass-renderer.SwiftAssRenderer\/tutorials\/SwiftAssRenderer\/CustomImageDrawing#Custom-Drawing","title":"Custom Drawing","type":"section"},"customdrawing-16.swift":{"fileName":"SubtitlesViewController.swift","highlights":[{"line":7},{"line":13},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24}],"identifier":"customdrawing-16.swift","type":"file","syntax":"swift","fileType":"swift","content":["import UIKit","import Combine","import SwiftAssRenderer","","final class SubtitlesViewController: UIViewController {","    private let renderer = AssSubtitlesRenderer(fontConfig: FontConfig(fontsPath: ...))","    private let imageView = UIImageView()","    private var cancellables = Set<AnyCancellable>()","","    override func viewDidLoad() {","        super.viewDidLoad()","","        addImageView()","        loadSubtitleTrack()","        setupSubtitlesTimer()","        setupSubtitlesFrame()","        setupSubtitlesDrawing()","    }","","    private func addImageView() {","        view.addSubview(imageView)","        imageView.translatesAutoresizingMaskIntoConstraints = false","    }","","    private func loadSubtitleTrack() {","        Task {","            do {","                let contents = try await ...","                renderer.loadTrack(content: contents)","            } catch {","              