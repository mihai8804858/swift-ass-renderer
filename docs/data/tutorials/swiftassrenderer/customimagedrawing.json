{"metadata":{"role":"project","title":"Custom Drawing","categoryPathComponent":"Advanced-Tutorials","category":"Advanced"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftAssRenderer\/tutorials\/SwiftAssRenderer\/CustomImageDrawing"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[{"estimatedTimeInMinutes":10,"kind":"hero","chapter":"Custom Image Drawing","content":[{"inlineContent":[{"type":"text","text":"Learn how to manually integrate "},{"type":"codeVoice","code":"AssSubtitlesRenderer"},{"type":"text","text":" with your view."}],"type":"paragraph"}],"title":"Custom Drawing"},{"tasks":[{"title":"Custom Drawing","contentSection":[{"content":[{"inlineContent":[{"text":"In this section we will create a basic view controller and manually draw the processed ","type":"text"},{"type":"codeVoice","code":"CGImage"},{"text":" on the screen. We will also learn how we can periodically update the subtitles by creating a timer and updating the renderer, and also how we can subscribe to renderer frame changes and update the screen.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","media":"logo-rounded.png","mediaPosition":"trailing"}],"anchor":"Custom-Drawing","stepsSection":[{"media":null,"code":"customdrawing-1.swift","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Let’s start by creating a new view controller called "},{"code":"SubtitlesViewController","type":"codeVoice"},{"type":"text","text":". We also need to import "},{"code":"UIKit","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"SwiftAssRenderer"},{"type":"text","text":"."}],"type":"paragraph"}],"runtimePreview":null},{"code":"customdrawing-2.swift","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Next, let’s create our renderer. We need to at least specify the URL path where the fonts are located that will be used to render the subtitles.","type":"text"}]}],"type":"step","media":null},{"type":"step","code":"customdrawing-3.swift","caption":[],"runtimePreview":null,"media":null,"content":[{"inlineContent":[{"text":"We’ll have to do some setup in ","type":"text"},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" so let’s override it."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"We need a method called from ","type":"text"},{"type":"codeVoice","code":"viewDidLoad()"},{"text":" that will load the subtitle contents and provide it to renderer.","type":"text"}],"type":"paragraph"}],"type":"step","runtimePreview":null,"code":"customdrawing-4.swift","media":null,"caption":[]},{"media":null,"code":"customdrawing-5.swift","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Next, let’s load the subtitles contents, either from local disk for web.","type":"text"}]}],"type":"step"},{"type":"step","content":[{"inlineContent":[{"text":"After contents have been loaded, we need to provide the contents for the renderer by calling ","type":"text"},{"code":"loadTrack(contents:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"media":null,"code":"customdrawing-6.swift","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"We need another method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" that will create a "},{"code":"Timer","type":"codeVoice"},{"type":"text","text":" to periodically update the subtitles time offset."}],"type":"paragraph"}],"code":"customdrawing-7.swift","type":"step","media":null,"runtimePreview":null,"caption":[]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Let’s setup the timer to fire each 0.1 seconds on ","type":"text"},{"type":"codeVoice","code":".main"},{"text":" queue.","type":"text"}]}],"code":"customdrawing-8.swift","type":"step","runtimePreview":null,"caption":[]},{"runtimePreview":null,"code":"customdrawing-9.swift","content":[{"inlineContent":[{"text":"In the timer output closure, we need to update the renderer with the time offset since the start date.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","caption":[]},{"code":"customdrawing-10.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"We need another method called from "},{"type":"codeVoice","code":"viewDidLoad()"},{"text":" that will subscribe to view’s frame changes and update the renderer’s canvas size and scale.","type":"text"}],"type":"paragraph"}],"caption":[],"media":null,"runtimePreview":null},{"media":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"We can use ","type":"text"},{"code":"Combine","type":"codeVoice"},{"type":"text","text":"’s KVO publisher to subscribe to "},{"type":"codeVoice","code":"frame"},{"type":"text","text":" changes and execute a closure."}]}],"type":"step","caption":[],"code":"customdrawing-11.swift"},{"runtimePreview":null,"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"frame","type":"codeVoice"},{"type":"text","text":" changed, we need to update the canvas size by calling "},{"code":"setCanvasSize(_:scale:)","type":"codeVoice"},{"type":"text","text":" on renderer,"},{"text":" ","type":"text"},{"type":"text","text":"we can use the display scale as the scale at which the images will be created."}]}],"code":"customdrawing-12.swift","caption":[]},{"code":"customdrawing-13.swift","caption":[],"content":[{"inlineContent":[{"type":"text","text":"We need another method called from "},{"type":"codeVoice","code":"viewDidLoad()"},{"text":" that will subscribe to renderer’s frame changes and update the drawn image.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":null,"type":"step"},{"type":"step","code":"customdrawing-14.swift","runtimePreview":null,"content":[{"inlineContent":[{"type":"codeVoice","code":"AssSubtitlesRenderer"},{"type":"text","text":" privides a publisher where the image changes are being published so they can be drawn on the screen."}],"type":"paragraph"}],"caption":[],"media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a new processed image arrives, we need to handle it so let’s create a separate method for it."}]}],"type":"step","runtimePreview":null,"caption":[],"media":null,"code":"customdrawing-15.swift"},{"media":null,"caption":[],"content":[{"inlineContent":[{"text":"Do display the processed image, we can use an ","type":"text"},{"code":"UIImageView","type":"codeVoice"},{"type":"text","text":", so let’s create one and add it as a subview."},{"type":"text","text":" "},{"text":"We don’t need to setup any autolayout constraints since we will manually update the image view frame based on processed image rect provided to us by the renderer.","type":"text"}],"type":"paragraph"}],"type":"step","code":"customdrawing-16.swift","runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the processed image handler, we can check if we have an image to render or not, if not we can reset the image view and hide it."},{"type":"text","text":" "},{"type":"text","text":"When we do have an image, let’s assign that image to image view and update the image view frame to processed image rect."}]}],"caption":[],"runtimePreview":null,"type":"step","code":"customdrawing-17.swift","media":null},{"code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, let’s run the app. And as expected, we can see the subtitles showing and being updated."}]}],"caption":[],"type":"step","media":"custom-drawing.gif"}]}],"kind":"tasks"},{"abstract":[{"text":"Learn how to create a custom image pipeline to process and combine the incoming images into a final image.","type":"text"}],"title":"Custom Processing","kind":"callToAction","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],