"customdrawing-4.swift","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"We need a method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"text":" that will load the subtitle contents and provide it to renderer.","type":"text"}],"type":"paragraph"}]},{"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, let’s load the subtitles contents, either from local disk for web."}]}],"caption":[],"code":"customdrawing-5.swift","media":null},{"type":"step","content":[{"inlineContent":[{"text":"After contents have been loaded, we need to provide the contents for the renderer by calling ","type":"text"},{"code":"loadTrack(contents:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"media":null,"code":"customdrawing-6.swift","runtimePreview":null},{"code":"customdrawing-7.swift","runtimePreview":null,"caption":[],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We need another method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" that will create a "},{"code":"Timer","type":"codeVoice"},{"type":"text","text":" to periodically update the subtitles time offset."}]}]},{"runtimePreview":null,"caption":[],"code":"customdrawing-8.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Let’s setup the timer to fire each 0.1 seconds on ","type":"text"},{"type":"codeVoice","code":".main"},{"text":" queue.","type":"text"}]}],"type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the timer output closure, we need to update the renderer with the time offset since the start date.","type":"text"}]}],"type":"step","caption":[],"media":null,"code":"customdrawing-9.swift","runtimePreview":null},{"media":null,"content":[{"inlineContent":[{"type":"text","text":"We need another method called from "},{"code":"viewDidLoad()","type":"codeVoice"},{"type":"text","text":" that will subscribe to view’s frame changes and update the renderer’s canvas size and scale."}],"type":"paragraph"}],"type":"step","caption":[],"code":"customdrawing-10.swift","runtimePreview":null},{"code":"customdrawing-11.swift","runtimePreview":null,"type":"step","caption":[],"media":null,"content":[{"inlineContent":[{"text":"We can use ","type":"text"},{"code":"Combine","type":"codeVoice"},{"text":"’s KVO publisher to subscribe to ","type":"text"},{"code":"frame","type":"codeVoice"},{"type":"text","text":" changes and execute a closure."}],"type":"paragraph"}]},{"runtimePreview":null,"type":"step","code":"customdrawing-12.swift","content":[{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"frame"},{"type":"text","text":" changed, we need to update the canvas size by calling "},{"code":"setCanvasSize(_:scale:)","type":"codeVoice"},{"type":"text","text":" on renderer,"},{"type":"text","text":" "},{"type":"text","text":"we can use the display scale as the scale at which the images will be created."}]}],"media":null,"caption":[]},{"media":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We need another method called from "},{"type":"codeVoice","code":"viewDidLoad()"},{"type":"text","text":" that will subscribe to renderer’s frame changes and update the drawn image."}]}],"type":"step","code":"customdrawing-13.swift","runtimePreview":null},{"code":"customdrawing-14.swift","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"code":"AssSubtitlesRenderer","type":"codeVoice"},{"type":"text","text":" privides a publisher where the image changes are being published so they can be drawn on the screen."}]}],"type":"step","media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"When a new processed image arrives, we need to handle it so let’s create a separate method for it.","type":"text"}]}],"media":null,"capt