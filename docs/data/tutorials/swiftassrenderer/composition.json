{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftAssRenderer\/tutorials\/SwiftAssRenderer\/Composition"},"sections":[{"chapter":"Composition Integration","title":"Composition Integration","estimatedTimeInMinutes":5,"content":[{"type":"paragraph","inlineContent":[{"text":"Learn how to easily integrate ","type":"text"},{"code":"SwiftAssRenderer","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"AVPlayerItem"},{"type":"text","text":" by burning the subtitles in the video on the fly."}]}],"kind":"hero"},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"In this section we will create a basic video player using ","type":"text"},{"code":"VideoPlayer","type":"codeVoice"},{"type":"text","text":" from "},{"type":"codeVoice","code":"SwiftUI"},{"text":", and we will add the subtitles into the video by burning them on the fly.","type":"text"}],"type":"paragraph"}],"media":"logo-rounded.png"}],"title":"Composition","anchor":"Composition","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s start by creating a new view and naming it "},{"type":"codeVoice","code":"VideoPlayerView"},{"text":". We also need to import ","type":"text"},{"type":"codeVoice","code":"SwiftUI"},{"text":", ","type":"text"},{"type":"codeVoice","code":"AVKit"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"SwiftAssRenderer"},{"type":"text","text":"."}]}],"code":"composition-1.swift","type":"step","media":null,"caption":[],"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will need an instance of "},{"type":"codeVoice","code":"AVURLAsset"},{"type":"text","text":", "},{"type":"codeVoice","code":"AVPlayerItem"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"AVPlayer"},{"text":". Let’s create an asset by providing either a local or remove URL (